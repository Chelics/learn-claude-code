# 论文研究分析 Agent 配置

# 搜索配置
MAX_SEARCH_RESULTS=30          # 最大搜索结果数
CACHE_DAYS=1                   # 缓存有效期（天）
RELEVANCE_THRESHOLD=0.6        # 相关性阈值

# 分析配置
NOVELTY_THRESHOLD=0.7          # 新颖性阈值
MIN_PAPER_QUALITY=0.5          # 最低论文质量分数

# 报告配置
MAX_REPORT_PAPERS=15           # 报告中包含的最大论
SHOW_CHARTS=true              # 是否生成图表
REPORT_LANGUAGE=zh            # 报告语言（zh/en）

# 存储路径
PAPERS_DIR=data/papers         # 论文存储目录
REPORTS_DIR=data/reports       # 报告存储目录
CACHE_DIR=data/search_cache    # 缓存目录

# API配置（如需使用其他API）
# OPENAI_API_KEY=your_api_key_here
# HUGGINGFACE_API_TOKEN=your_token_here
